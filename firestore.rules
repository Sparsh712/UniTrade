rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isOrderParticipantFromResource() {
      return signedIn()
        && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
    }

    function isOrderParticipantFromRequest() {
      return signedIn()
        && (request.resource.data.buyerId == request.auth.uid || request.resource.data.sellerId == request.auth.uid);
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.ownerId);
    }

    match /orders/{orderId} {
      allow read: if isOrderParticipantFromResource();
      allow create: if isOrderParticipantFromRequest();
      allow update: if isOrderParticipantFromResource();
      allow delete: if false;
    }

    // Buyer-only OTP plaintext storage. Seller verifies using hash in /orders.
    match /orderSecrets/{orderId} {
      allow create: if signedIn() && request.resource.data.buyerId == request.auth.uid;
      allow read, update, delete: if signedIn() && resource.data.buyerId == request.auth.uid;
    }

    match /wishlists/{userId} {
      allow read, create, update, delete: if isOwner(userId);
    }
  }
}
